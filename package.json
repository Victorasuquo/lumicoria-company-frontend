{
  "name": "lumicoria-company-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "api:docs": "node scripts/generate-api-docs.mjs",
    "api:sync": "npm run api:types && npm run api:docs",
    "api:types": "openapi-typescript http://127.0.0.1:8000/openapi/client.json --output src/api/generated/schema.ts",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/space-grotesk": "^5.3.0",
    "@fontsource/space-mono": "^5.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.101.4",
    "firebase": "^12.16.0",
    "motion": "^12.42.2",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.5"
  },
  "overrides": {
    "js-yaml": "^4.3.0"
  }
}
